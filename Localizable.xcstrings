  "sourceLanguage": "en",
  "strings": {
    "": {
      "comment": "Context: Empty SwiftUI label from an icon-only or hidden control. Surrounding UI supplies the visible icon; keep the translation blank.",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": ""
          }
        }
      }
    },
    "**[More...](https://github.com/Manhhao/Hoshi-Reader/blob/develop/SASAYAKI.md)**": {
      "comment": "Context: Sasayaki audiobook feature screens. Surrounding UI includes setup instructions, SRT/audio matching, playback controls, command center options, and Sasayaki theme settings. Preserve Markdown and product names.",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "**[更多…](https://github.com/Manhhao/Hoshi-Reader/blob/develop/SASAYAKI.md)**"
          }
        }
      }
    },
    "**%@ / h**": {
      "comment": "Context: Formatter-only value in reader statistics, progress rows, or setting value labels. Surrounding UI provides the label; keep placeholders, Markdown, and percent signs unchanged.",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "**%@ / 小时**"
          }
        }
      }
    },
