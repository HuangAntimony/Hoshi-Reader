    "%lld / %lld (%@)": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$lld / %2$lld (%3$@)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
